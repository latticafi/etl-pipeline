<?xml version="1.0"?>
<!--
    Lattica ClickHouse config override.
    Merged with base /etc/clickhouse-server/config.xml at startup.

    Defines tiered storage:
      - default disk:  local NVMe (hot, fast, recent data)
      - r2 disk:       Cloudflare R2 (cold, slow, historical data)
      - policy 'tiered': hot first, moves to cold on TTL
-->
<clickhouse>
    <logger>
        <level>information</level>
    </logger>

    <!-- Memory limits — assumes 4GB container. Adjust if running on a
         bigger host. -->
    <max_server_memory_usage>3221225472</max_server_memory_usage>
    <max_memory_usage_for_user>2147483648</max_memory_usage_for_user>

    <background_pool_size>8</background_pool_size>
    <background_merges_mutations_concurrency_ratio>2</background_merges_mutations_concurrency_ratio>

    <async_insert>1</async_insert>
    <wait_for_async_insert>1</wait_for_async_insert>
    <async_insert_max_data_size>1048576</async_insert_max_data_size>
    <async_insert_busy_timeout_ms>1000</async_insert_busy_timeout_ms>

    <!-- ===================================================================
         Tiered storage: local NVMe (hot) + Cloudflare R2 (cold)
         ===================================================================

         Credentials are passed via docker-compose from .env. The
         `from_env="VAR_NAME"` attribute tells ClickHouse to read the value
         from that environment variable at startup, so nothing sensitive
         goes in VCS.
    -->
    <storage_configuration>
        <disks>
            <!-- Local default disk is implicit; no declaration needed. -->

            <r2>
                <type>s3</type>
                <endpoint from_env="R2_ENDPOINT"/>
                <access_key_id from_env="R2_ACCESS_KEY_ID"/>
                <secret_access_key from_env="R2_SECRET_ACCESS_KEY"/>
                <region>auto</region>
                <!-- R2 requires path-style addressing; force it. -->
                <use_virtual_addressing>false</use_virtual_addressing>
                <!-- Performance tuning: larger uploads = fewer round trips. -->
                <min_upload_part_size>16777216</min_upload_part_size>
                <max_single_part_upload_size>33554432</max_single_part_upload_size>
                <!-- Local cache on top of S3 disk dramatically speeds up
                     repeat reads. Cap cache at a few GB on the workstation. -->
                <cache_enabled>true</cache_enabled>
                <cache_path>/var/lib/clickhouse/disks/r2_cache/</cache_path>
                <cache_size>3221225472</cache_size>  <!-- 3 GiB -->
            </r2>
        </disks>

        <policies>
            <tiered>
                <volumes>
                    <hot>
                        <disk>default</disk>
                    </hot>
                    <cold>
                        <disk>r2</disk>
                    </cold>
                </volumes>
                <!-- When the hot volume hits 80% full, start moving old parts
                     to cold even before TTL fires. Safety valve. -->
                <move_factor>0.2</move_factor>
            </tiered>
        </policies>
    </storage_configuration>
</clickhouse>
